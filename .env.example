#
# Environment variable template
# Copy to .env.local and fill in real values (never commit .env.local)
#

# Site URL (SEO: metadataBase, sitemap, canonical, OG)
NEXT_PUBLIC_SITE_URL="https://your-project.vercel.app"

# Google Search Console（HTML タグ方式の content 値）
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION="your-google-verification-token"

# Social / contact (SEO: Footer links, JSON-LD sameAs)
NEXT_PUBLIC_INSTAGRAM_URL="https://www.instagram.com/your-account"
NEXT_PUBLIC_CONTACT_EMAIL="hello@example.com"

# Turso (libSQL)
TURSO_DATABASE_URL="libsql://your-database.turso.io"
TURSO_AUTH_TOKEN="YOUR_TURSO_AUTH_TOKEN"

# Clerk (Google login only)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="YOUR_CLERK_PUBLISHABLE_KEY"
CLERK_SECRET_KEY="YOUR_CLERK_SECRET_KEY"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/login"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/admin"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/admin"

# Clerk webhook (user.created — delete non-admin sign-ups)
# Dashboard → Webhooks → Add Endpoint → https://your-domain/api/webhooks/clerk
CLERK_WEBHOOK_SIGNING_SECRET="whsec_YOUR_WEBHOOK_SIGNING_SECRET"

# Admin allowlist (Google account email)
ADMIN_EMAIL="your-admin-email@example.com"

# Cloudflare R2 (S3 compatible)
R2_ACCOUNT_ID="YOUR_R2_ACCOUNT_ID"
R2_ACCESS_KEY_ID="YOUR_R2_ACCESS_KEY_ID"
R2_SECRET_ACCESS_KEY="YOUR_R2_SECRET_ACCESS_KEY"
R2_BUCKET_NAME="YOUR_R2_BUCKET_NAME"
R2_PUBLIC_URL="https://YOUR_R2_PUBLIC_DOMAIN"
